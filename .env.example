# ═══════════════════════════════════════════
# FSTM Chatbot — Variables d'environnement
# ═══════════════════════════════════════════
# Copiez ce fichier en .env et remplissez les valeurs :
#   cp .env.example .env

# Jina AI — Clé API pour les embeddings (https://jina.ai)
JINA_API_KEY=

# n8n — Clé de chiffrement pour les workflows
N8N_ENCRYPTION_KEY=

# Qdrant — URL de la base vectorielle
QDRANT_URL=http://localhost:6333
