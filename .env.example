# ════════════════════════════════════════════════════════════════════════
# FSTM PORTAL - CONFIGURATION TEMPLATE
# ════════════════════════════════════════════════════════════════════════
# Copiez ce fichier et nommez-le ".env" puis remplissez vos clés privées.

# Clé API Jina (nécessaire pour l'indexation et les embeddings)
# Obtenez-en une sur : https://jina.ai/
JINA_API_KEY=jina_...

# URL de Qdrant (Base de données vectorielle)
# Utiliser http://localhost:6333 si vous lancez Docker localement
QDRANT_URL=http://localhost:6333

# Clé de chiffrement n8n (Obligatoire pour la sécurité des workflows)
N8N_ENCRYPTION_KEY=choisissez_une_phrase_longue_et_secrete

# (Optionnel) Clé OpenAI si vous utilisez des modèles GPT
OPENAI_API_KEY=sk-...
